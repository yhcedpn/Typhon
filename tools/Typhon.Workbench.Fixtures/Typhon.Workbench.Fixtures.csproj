<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <LangVersion>default</LangVersion>
        <IsPackable>false</IsPackable>
        <Nullable>disable</Nullable>
        <!-- Assembly simple name is "Typhon.Workbench.Fixtures.schema"; the on-disk file is therefore Typhon.Workbench.Fixtures.schema.dll, which the
             Workbench's manifest resolver locates via its fast {SimpleName}.dll probe next to the database file. -->
        <AssemblyName>Typhon.Workbench.Fixtures.schema</AssemblyName>
        <RootNamespace>Typhon.Workbench.Fixtures</RootNamespace>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\Typhon.Engine\Typhon.Engine.csproj" />
        <!-- Direct ref (#427): Schema.Definition ships bundled inside the Typhon package, no longer transitive via the engine. -->
        <ProjectReference Include="..\..\src\Typhon.Schema.Definition\Typhon.Schema.Definition.csproj" />
        <!-- Needed by TraceFixtureBuilder / MockTcpProfilerServer for TraceFileHeader, TraceFileWriter,
             LiveStreamProtocol, TraceBlockEncoder. -->
        <ProjectReference Include="..\..\src\Typhon.Profiler\Typhon.Profiler.csproj" />
    </ItemGroup>

    <ItemGroup>
        <!-- Source generators / analyzers the Typhon.Engine types depend on at compile time. -->
        <ProjectReference Include="..\..\src\Typhon.Analyzers\Typhon.Analyzers.csproj" ReferenceOutputAssembly="false" OutputItemType="Analyzer" />
        <ProjectReference Include="..\..\src\Typhon.Generators\Typhon.Generators.csproj" ReferenceOutputAssembly="false" OutputItemType="Analyzer" />
    </ItemGroup>

    <ItemGroup>
        <!-- The fixture database generator is internal so it never becomes part of the public API
             surface for user schema DLLs. The Workbench (DEBUG-only Dev Fixture tab) and the engine
             test project are the only intended callers. -->
        <InternalsVisibleTo Include="Typhon.Workbench" />
        <InternalsVisibleTo Include="Typhon.Engine.Tests" />
        <InternalsVisibleTo Include="Typhon.Workbench.Tests" />
    </ItemGroup>

</Project>
